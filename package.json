{
  "name": "firestorm-db",
  "version": "2.0.0",
  "description": "Self hosted Firestore-like database with API endpoints based on micro bulk operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "js:build": "tsc --build tsconfig.json",
    "js:tests": "pnpm js:build && mocha tests/**/tests-setup.spec.mjs tests/**/*.spec.mjs",
    
    "php:start": "node tests/php/php_setup.mjs",
    "php:stop": "sh tests/php/php_server_kill.sh",
    "php:tests": "pnpm php:stop; pnpm php:start && pnpm js:tests && pnpm php:stop",

    "docker:build": "pnpm js:build ; bash docker/docker_image_build.bash",
    "docker:alive": "bash docker/docker_image_alive.bash",
    "docker:tests": "bash docker/docker_image_tests.bash",
    "docker:start": "bash docker/docker_image_start.bash",

    "doc:gen": "pnpm typedoc src/typescript --plugin typedoc-plugin-rename-defaults --plugin typedoc-github-theme --favicon ./resources/img/firestorm-128.png --customCss ./resources/doc.css --jsDocCompatibility --highlightLanguages ts --highlightLanguages json --highlightLanguages php --highlightLanguages sh --highlightLanguages js --highlightLanguages ini",
    
    "lint:prettier": "prettier \"{,!(node_modules)/**/}*.{cjs,mjs,js,ts}\" --config .prettierrc --write"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheRolfFR/firestorm-db"
  },
  "keywords": [
    "firebase",
    "firestore",
    "db",
    "api",
    "micro-operations",
    "bulk"
  ],
  "author": "TheRolf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TheRolfFR/firestorm/issues"
  },
  "homepage": "https://therolffr.github.io/firestorm-db/",
  "files": [
    "dist/index.js",
    "dist/index.d.ts"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "form-data": "^4.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "chai": "^6.0.1",
    "consola": "^3.4.2",
    "glob": "^11.0.3",
    "mocha": "^11.7.1",
    "prettier": "^3.6.2",
    "recursive-copy": "^2.0.14",
    "tsdoc-markdown": "^1.4.1",
    "typedoc": "^0.28.10",
    "typedoc-github-theme": "^0.3.1",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typescript": "^5.9.2"
  }
}
